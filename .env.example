# ── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ──────────────────────────────────────────────────
# Local (Termux):    mongodb://127.0.0.1:27017/plugme
# Atlas (Cloud):     mongodb+srv://USER:PASS@cluster.mongodb.net/plugme
MONGODB_URI=mongodb://127.0.0.1:27017/plugme

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CHANGE_THIS_REFRESH_SECRET_TOO
JWT_REFRESH_EXPIRES_IN=30d

# ── Frontend URL (CORS) ──────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ── OpenAI (AI request optimizer) ───────────────────────────
# Leave blank to use fallback optimizer (no OpenAI needed for MVP)
OPENAI_API_KEY=

# ── Payment Gateway (Paystack) ───────────────────────────────
# Sign up at paystack.com — free for Nigerian businesses
PAYSTACK_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
PAYSTACK_PUBLIC_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Contact Unlock Price (kobo — 99 NGN = 9900 kobo) ─────────
UNLOCK_PRICE_KOBO=9900

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
